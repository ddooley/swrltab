#!/usr/bin/env bash
# Wrapper for SWRLTabCLI.
# Usage: swrltabcli [options] <ontology.owl|ofn>
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
JAR="$SCRIPT_DIR/target/swrltab-2.1.2-jar-with-dependencies.jar"

if [ ! -f "$JAR" ]; then
  echo "Error: fat JAR not found. Run 'mvn clean package' in $SCRIPT_DIR first." >&2
  exit 1
fi

exec java -cp "$JAR" org.swrltab.ui.SWRLTabCLI "$@"
